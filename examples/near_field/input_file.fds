&RAMP ID='dir', Z=16.00, F=357.34
&RAMP ID='dir', Z=21.00, F=358.20
&RAMP ID='dir', Z=26.00, F=359.21
&RAMP ID='dir', Z=31.00, F=359.23
&RAMP ID='dir', Z=39.00, F=0.56

