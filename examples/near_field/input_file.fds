&SPEC ID='METHANE'/
&SURF ID='METHANE BLOWER', MASS_FLUX(1)=17.22, SPEC_ID(1)='METHANE', COLOR='RED'/
&SURF ID='GROUND', ROUGHNESS=0.978, TMP_FRONT=15.72/

&OBST XB= -0.08, 0.08, -0.08, 0.08, 95.11, 96.61 / 
&VENT XB= -0.08, 0.08, -0.08, 0.08, 96.61, 96.61, SURF_ID='METHANE BLOWER' / 

&VENT DB=XMIN, SURF_ID ='PERIODIC FLOW ONLY' /  
&VENT DB=XMAX, SURF_ID ='PERIODIC FLOW ONLY' /  
&VENT DB=YMIN, SURF_ID ='PERIODIC FLOW ONLY' /  
&VENT DB=YMAX, SURF_ID ='PERIODIC FLOW ONLY' /  
&VENT DB=ZMIN, SURF_ID ='GROUND' /
&VENT DB=ZMAX, SURF_ID ='OPEN' / 

&SLCF XB= -48.6, 48.6, -48.6, 48.6, 86.0, 183.2, QUANTITY='TEMPERATURE', VECTOR=.TRUE. /
&SLCF XB= -48.6, 48.6, -48.6, 48.6, 86.0, 183.2, QUANTITY='VELOCITY', VECTOR=.TRUE. / 
